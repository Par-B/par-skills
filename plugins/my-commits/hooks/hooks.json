{
  "description": "Auto-approve the my-commits plugin's own read-only render script. Scoped via `if` to ONLY this scanner (any args). It shells out to READ-ONLY git (rev-parse/config/log). Write actions are not involved. Consent is granted at plugin install/trust time.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(python3 \"${CLAUDE_PLUGIN_ROOT}/skills/my-commits/scripts/my_commits.py\":*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"my-commits read-only git report\"}}'"
          },
          {
            "type": "command",
            "if": "Bash(python3 ${CLAUDE_PLUGIN_ROOT}/skills/my-commits/scripts/my_commits.py:*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"my-commits read-only git report\"}}'"
          }
        ]
      }
    ]
  }
}
