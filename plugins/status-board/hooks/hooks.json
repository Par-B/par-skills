{
  "description": "Auto-approve the status-board plugin's own read-only render script. Scoped via `if` to ONLY this bundled scanner (any --scope arg); never touches other commands. The plugin's write actions (bootstrap mkdir/cp) are deliberately NOT covered and still prompt. User consent is granted at plugin install/trust time.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(python3 \"${CLAUDE_PLUGIN_ROOT}/skills/status-board/scripts/status_board.py\":*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"status-board read-only render\"}}'"
          },
          {
            "type": "command",
            "if": "Bash(python3 ${CLAUDE_PLUGIN_ROOT}/skills/status-board/scripts/status_board.py:*)",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"status-board read-only render\"}}'"
          }
        ]
      }
    ]
  }
}
